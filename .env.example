# AdventiTune — Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit your actual .env file to git

# ========================
# SUPABASE (Database)
# ========================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ========================
# FIREBASE (Authentication)
# ========================
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ========================
# CLOUDFLARE R2 (Audio Storage)
# ========================
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=adventitune-audio
R2_PUBLIC_URL=https://your-bucket.r2.dev

# ========================
# FLUTTERWAVE (Payments)
# ========================
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-your_public_key
FLUTTERWAVE_SECRET_KEY=FLWSECK-your_secret_key
FLUTTERWAVE_ENCRYPTION_KEY=your_encryption_key
FLUTTERWAVE_WEBHOOK_SECRET=your_webhook_secret

# ========================
# APPLICATION
# ========================
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000/v1
JWT_SECRET=your_jwt_secret_for_any_internal_tokens

# ========================
# MOBILE APP (Expo)
# ========================
EXPO_PUBLIC_API_URL=http://localhost:3000/v1
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
EXPO_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-your_public_key
